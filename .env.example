# Anthropic API key — used by the extract + compare pipeline stages.
# Get one at https://console.anthropic.com/ . Copy this file to `.env` and fill in.
ANTHROPIC_API_KEY=

# SQLite connection string for Prisma. The default writes a local file.
DATABASE_URL="file:./dev.db"

# Optional: cap how many pages the crawler fetches per center (default 25).
CRAWL_MAX_PAGES_PER_CENTER=25

# Optional: milliseconds to wait between requests to the same host (default 1500).
CRAWL_THROTTLE_MS=1500
